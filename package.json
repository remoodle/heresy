{
  "name": "heresy",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "ready": "vp fmt && vp lint && vp run -r test && vp run -r build",
    "check": "vp lint && vp run -r test && vp run -r build",
    "prepare": "vp config",
    "format": "vp fmt",
    "lint": "vp lint",
    "type-check": "vp run -r type-check",
    "test": "vp run -r test",
    "build": "vp run -r build",
    "dev:calendar": "vp run @heresy/calendar#dev",
    "dev:remoodle": "vp run @heresy/remoodle#dev"
  },
  "devDependencies": {
    "vite-plus": "catalog:"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@hatchet-dev/typescript-sdk",
      "better-sqlite3",
      "esbuild",
      "protobufjs"
    ]
  }
}
