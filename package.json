{
  "name": "heresy",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "ready": "vp fmt && vp run lint && vp run -r test && vp run -r build",
    "check": "vp run lint && vp run -r test && vp run -r build",
    "format": "vp fmt",
    "prelint": "vp run @heresy/remoodle#paraglide:compile",
    "lint": "vp lint",
    "type-check": "vp run -r type-check",
    "test": "vp run -r test",
    "build": "vp run -r build",
    "dev": "vp run -F @heresy/calendar -F @heresy/remoodle dev",
    "dev:calendar": "vp run @heresy/calendar#dev",
    "dev:remoodle": "vp run @heresy/remoodle#dev",
    "clean:remoodle": "rm -f apps/remoodle/remoodle.db apps/remoodle/remoodle.db-shm apps/remoodle/remoodle.db-wal",
    "generate:remoodle": "vp run @heresy/remoodle#db:generate",
    "migrate:remoodle": "vp run @heresy/remoodle#db:migrate"
  },
  "devDependencies": {
    "vite-plus": "catalog:"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@hatchet-dev/typescript-sdk",
      "better-sqlite3",
      "esbuild",
      "protobufjs"
    ]
  }
}
