{
  "name": "@heresy/remoodle",
  "version": "0.15.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "run-p dev:bot dev:worker",
    "dev:bot": "tsx watch src/bot/index.ts | pino-pretty",
    "dev:worker": "tsx src/worker/index.ts",
    "start": "run-p start:bot start:worker",
    "build": "vp pack",
    "test": "vitest run",
    "start:bot": "node dist/db/migrate.mjs && node dist/bot/index.mjs",
    "start:worker": "node dist/db/migrate.mjs && node dist/worker/index.mjs",
    "format": "oxfmt .",
    "lint": "oxlint .",
    "type-check": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@grammyjs/hydrate": "^1.6.0",
    "@hatchet-dev/typescript-sdk": "^1.19.1",
    "@libsql/client": "^0.17.2",
    "callback-data": "^1.1.1",
    "dayjs": "^1.11.19",
    "dotenv": "^17.2.3",
    "drizzle-orm": "1.0.0-beta.21",
    "envalid": "^8.1.1",
    "grammy": "^1.38.3",
    "hono": "^4.12.5",
    "pino": "^10.1.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "drizzle-kit": "1.0.0-beta.21",
    "npm-run-all2": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "tsdown": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "exports": {
    "./bot": "./dist/bot/index.mjs",
    "./bot/bot": "./dist/bot/bot.mjs",
    "./bot/callback-data": "./dist/bot/callback-data.mjs",
    "./bot/context": "./dist/bot/context.mjs",
    "./bot/features/courses": "./dist/bot/features/courses.mjs",
    "./bot/features/deadlines": "./dist/bot/features/deadlines.mjs",
    "./bot/features/schedule": "./dist/bot/features/schedule.mjs",
    "./bot/features/settings": "./dist/bot/features/settings.mjs",
    "./bot/features/start": "./dist/bot/features/start.mjs",
    "./bot/keyboards/menu": "./dist/bot/keyboards/menu.mjs",
    "./config": "./dist/config.mjs",
    "./db": "./dist/db/index.mjs",
    "./db/migrate": "./dist/db/migrate.mjs",
    "./db/schema": "./dist/db/schema.mjs",
    "./library/calendar": "./dist/library/calendar.mjs",
    "./library/calendar-api": "./dist/library/calendar-api.mjs",
    "./library/dates": "./dist/library/dates.mjs",
    "./library/deadline-reminders": "./dist/library/deadline-reminders.mjs",
    "./library/logger": "./dist/library/logger.mjs",
    "./library/schedule": "./dist/library/schedule.mjs",
    "./library/telegram": "./dist/library/telegram.mjs",
    "./worker": "./dist/worker/index.mjs",
    "./worker/hatchet-client": "./dist/worker/hatchet-client.mjs",
    "./worker/workflows/calendar-fetch-user": "./dist/worker/workflows/calendar-fetch-user.mjs",
    "./worker/workflows/deadline-check": "./dist/worker/workflows/deadline-check.mjs",
    "./worker/workflows/deadline-check-user": "./dist/worker/workflows/deadline-check-user.mjs",
    "./worker/workflows/deadline-notify-user": "./dist/worker/workflows/deadline-notify-user.mjs",
    "./worker/workflows/schedule-check": "./dist/worker/workflows/schedule-check.mjs",
    "./worker/workflows/schedule-check-user": "./dist/worker/workflows/schedule-check-user.mjs",
    "./worker/workflows/telegram-send-message": "./dist/worker/workflows/telegram-send-message.mjs",
    "./package.json": "./package.json"
  }
}
