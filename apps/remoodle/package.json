{
  "name": "@heresy/remoodle",
  "version": "0.16.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "run-p dev:bot dev:worker",
    "dev:bot": "tsx watch src/bot/index.ts | pino-pretty",
    "dev:worker": "tsx src/worker/index.ts",
    "start": "run-p start:bot start:worker",
    "build": "tsdown",
    "test": "vp test",
    "start:bot": "node dist/db/migrate.mjs && node dist/bot/index.mjs",
    "start:worker": "node dist/db/migrate.mjs && node dist/worker/index.mjs",
    "format": "oxfmt .",
    "lint": "oxlint .",
    "type-check": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@grammyjs/hydrate": "^1.6.0",
    "@hatchet-dev/typescript-sdk": "^1.19.1",
    "@libsql/client": "^0.17.2",
    "callback-data": "^1.1.1",
    "dayjs": "^1.11.19",
    "dotenv": "^17.2.3",
    "drizzle-orm": "catalog:",
    "envalid": "^8.1.1",
    "grammy": "^1.38.3",
    "hono": "^4.12.5",
    "lru-cache": "catalog:",
    "pino": "^10.1.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "drizzle-kit": "catalog:",
    "npm-run-all2": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "tsdown": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  }
}
