{
  "name": "@heresy/calendar",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "pnpm run build && wrangler dev",
    "build-only": "vp build",
    "type-check": "vue-tsc --build",
    "lint:oxlint": "oxlint . --fix -D correctness --ignore-path .gitignore",
    "lint:eslint": "eslint . --fix",
    "lint": "run-s lint:*",
    "format-check": "oxfmt --check src/ server/",
    "format": "oxfmt --write src/ server/",
    "deploy": "pnpm run build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "sync-dev": "jiti scripts/sync-dev.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply calendar-auth --local",
    "db:migrate:remote": "wrangler d1 migrations apply calendar-auth --remote --env-file .dev.vars",
    "db:studio": "drizzle-kit studio",
    "db:studio:remote": "DRIZZLE_ENV=remote drizzle-kit studio"
  },
  "dependencies": {
    "@iconify/vue": "^5.0.0",
    "@internationalized/date": "^3.8.2",
    "@schedule-x/calendar": "catalog:",
    "@schedule-x/calendar-controls": "catalog:",
    "@schedule-x/current-time": "catalog:",
    "@schedule-x/date-picker": "catalog:",
    "@schedule-x/event-modal": "catalog:",
    "@schedule-x/event-recurrence": "catalog:",
    "@schedule-x/events-service": "catalog:",
    "@schedule-x/ical": "catalog:",
    "@schedule-x/theme-default": "catalog:",
    "@schedule-x/theme-shadcn": "catalog:",
    "@schedule-x/vue": "catalog:",
    "@starredev/schedule-x-plugins": "^1.6.3",
    "@tailwindcss/vite": "^4.1.12",
    "@tanstack/query-persist-client-core": "^5.91.4",
    "@tanstack/vue-query": "^5.90.5",
    "@vueuse/core": "^13.7.0",
    "better-auth": "^1.5.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "catalog:",
    "drizzle-orm": "catalog:",
    "evlog": "catalog:",
    "hono": "catalog:",
    "lucide-vue-next": "^0.540.0",
    "pinia": "^3.0.3",
    "reka-ui": "^2.4.1",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.12",
    "tailwindcss-animate": "^1.0.7",
    "temporal-polyfill": "catalog:",
    "tw-animate-css": "^1.3.7",
    "vue": "^3.5.19",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.26.1",
    "@nerdfolio/drizzle-d1-helpers": "^0.1.5",
    "@tailwindcss/typography": "^0.5.16",
    "@tsconfig/node24": "^24.0.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "catalog:",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/tsconfig": "^0.8.1",
    "better-sqlite3": "^12.6.2",
    "dotenv": "catalog:",
    "drizzle-kit": "catalog:",
    "eslint": "^9.33.0",
    "eslint-plugin-oxlint": "^1.12.0",
    "eslint-plugin-vue": "^10.4.0",
    "jiti": "^2.5.1",
    "npm-run-all2": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-vue-devtools": "^8.0.0",
    "vite-plus": "catalog:",
    "vue-tsc": "^3.0.6",
    "wrangler": "catalog:"
  }
}
